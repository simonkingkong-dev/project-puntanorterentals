rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Colecciones públicas: lectura abierta, escritura solo vía Admin SDK
    match /properties/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /services/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /testimonials/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /globalAmenities/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /siteContent/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /contactInfo/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Reservaciones: sin acceso directo desde cliente (todo vía Admin SDK)
    match /reservations/{docId} {
      allow read, write: if false;
    }

    // Solo Admin SDK accede
    match /modificationRequests/{docId} {
      allow read, write: if false;
    }
    match /refundRequests/{docId} {
      allow read, write: if false;
    }
  }
}
