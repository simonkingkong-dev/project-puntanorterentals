# ========== Sitio ==========
NEXT_PUBLIC_SITE_URL=https://puntanorterentals.com

# ========== Firebase (cliente - navegador) ==========
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ========== Firebase Admin (servidor - solo backend) ==========
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com

# ========== Stripe ==========
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ========== Email (confirmación de reservas) ==========
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password

# ========== Admin Dashboard (acceso al panel /admin) ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# ========== Hostfully PMS (sincronización propiedades, calendario) ==========
# Agency UID: https://platform.hostfully.com/app/#/agency-settings
HOSTFULLY_API_KEY=your_hostfully_api_key
HOSTFULLY_AGENCY_UID=your_agency_uid
# Opcional; si no se define se usa sandbox
# HOSTFULLY_BASE_URL=https://api.hostfully.com/api/v3.2
# Persistir disponibilidad/precios desde Hostfully a Firestore (recomendado). Pon `false` solo en modo Hostfully-only.
# Si es `false`, el cron `sync-hostfully-availability` no escribe en Firestore.
HOSTFULLY_PERSIST_AVAILABILITY=true

# Secreto para llamar a los cron protegidos:
# - POST /api/cron/sync-hostfully-availability
# - POST /api/cron/sync-hostfully-analytics
# CRON_SECRET=your_cron_secret

# ========== Motor de reserva en la web pública ==========
# custom = flujo propio (calendario + formulario + Stripe propio) [default]
# hostfully = widgets Hostfully como fallback
# NEXT_PUBLIC_BOOKING_ENGINE=custom
#
# Para hostfully: copia el script URL del dashboard y el mismo agency UID (público):
# NEXT_PUBLIC_BOOKING_ENGINE=hostfully
# NEXT_PUBLIC_HOSTFULLY_AGENCY_UID=same_as_HOSTFULLY_AGENCY_UID
# NEXT_PUBLIC_HOSTFULLY_WIDGET_SCRIPT_SRC=https://... (src del <script> del snippet oficial)
# Opcional: URL de iframe si Hostfully te da enlace directo con {propertyUid} y {agencyUid}
# NEXT_PUBLIC_HOSTFULLY_BOOKING_IFRAME_URL=
# Si el snippet usa otros data-* en el div, ajústalos:
# NEXT_PUBLIC_HOSTFULLY_WIDGET_DATA_AGENCY_ATTR=data-hostfully-agency-uid
# NEXT_PUBLIC_HOSTFULLY_WIDGET_DATA_PROPERTY_ATTR=data-hostfully-property-uid
# NEXT_PUBLIC_HOSTFULLY_WIDGET_ROOT_CLASS=hostfully-booking-widget

# ---------- Widget Lead (leadCaptureWidget_2.0.js + pikaday) ----------
# UUID del 2º argumento de new Widget(...). Opcional si lo guardas por propiedad en Firestore.
# NEXT_PUBLIC_HOSTFULLY_LEAD_WIDGET_UUID=bd250250-08a1-49d8-b2ee-d49588fbaf9d
# JSON del 3º argumento (una sola línea o multilínea escapada). Opcional si lo pegas por propiedad en admin.
# NEXT_PUBLIC_HOSTFULLY_LEAD_WIDGET_OPTIONS_JSON={"type":"agency","pathRoot":"https://platform.hostfully.com/",...}
# NEXT_PUBLIC_HOSTFULLY_PIKADAY_SCRIPT=https://platform.hostfully.com/assets/js/pikaday.js
# NEXT_PUBLIC_HOSTFULLY_LEAD_CAPTURE_SCRIPT=https://platform.hostfully.com/assets/js/leadCaptureWidget_2.0.js
# ---------- Widget calendario Orbi (opcional) ----------
# NEXT_PUBLIC_HOSTFULLY_ORBI_CALENDAR_SCRIPT=https://platform.hostfully.com/assets/js/orbirental_calendar_widget_v2.js

# ========== Opcionales ==========
# URL base para redirects (Stripe, etc.)
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Fallback tipo de cambio USD→MXN si falla la API externa
# USD_MXN_RATE=17.2
