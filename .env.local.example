# ========== Firebase (cliente - navegador) ==========
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ========== Firebase Admin (servidor - solo backend) ==========
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com

# ========== Stripe ==========
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ========== Email (confirmación de reservas) ==========
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password

# ========== Admin Dashboard (acceso al panel /admin) ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# ========== Hostfully PMS (sincronización propiedades, calendario) ==========
# Agency UID: https://platform.hostfully.com/app/#/agency-settings
HOSTFULLY_API_KEY=your_hostfully_api_key
HOSTFULLY_AGENCY_UID=your_agency_uid
# Opcional; si no se define se usa sandbox
# HOSTFULLY_BASE_URL=https://api.hostfully.com/api/v3.2

# ========== Opcionales ==========
# URL base para redirects (Stripe, etc.)
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Fallback tipo de cambio USD→MXN si falla la API externa
# USD_MXN_RATE=17.2
