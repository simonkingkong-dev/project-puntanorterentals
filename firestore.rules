rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // REGLA PÚBLICA: Cualquiera puede leer propiedades, servicios, testimonios, etc.
    match /properties/{docId} {
      allow read: if true;
      allow write: if request.auth != null; // Solo usuarios autenticados (tu admin) pueden escribir
    }
    match /services/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /testimonials/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /globalAmenities/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /siteContent/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /contactInfo/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Reservaciones: solo lectura propia (guestEmail) o admin; escritura solo autenticado (admin en la práctica)
    match /reservations/{docId} {
      allow read: if request.auth != null
        && (resource.data.guestEmail == request.auth.token.email || request.auth.token.admin == true);
      allow write: if request.auth != null;
    }
  }
}